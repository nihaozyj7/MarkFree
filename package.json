{
  "name": "markfree",
  "version": "1.3.0",
  "private": true,
  "description": "A MarkFree editor built with Electron, React, and TipTap.",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "generate-icon": "node scripts/generate-icon.mjs",
    "pack": "node scripts/package.mjs",
    "pack:win": "node scripts/package.mjs --win",
    "pack:mac": "node scripts/package.mjs --mac",
    "pack:linux": "node scripts/package.mjs --linux",
    "pack:dir": "npm run generate-icon && npm run build && electron-builder --win --x64 --dir"
  },
  "build": {
    "appId": "com.markfree.app",
    "productName": "MarkFree",
    "compression": "maximum",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.png"
    },
    "portable": {
      "artifactName": "${productName}-${version}-${os}-${arch}-Portable.${ext}",
      "requestExecutionLevel": "user"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "MarkFree",
      "artifactName": "${productName}-${version}-${os}-${arch}-Setup.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "resources/icon.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.png",
      "category": "Office"
    },
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown",
        "description": "Markdown File",
        "role": "Editor"
      },
      {
        "ext": "markdown",
        "name": "Markdown",
        "description": "Markdown File",
        "role": "Editor"
      }
    ]
  },
  "dependencies": {
    "@tiptap/core": "^2.11.5",
    "@tiptap/extension-code-block-lowlight": "^2.11.5",
    "@tiptap/extension-image": "^2.11.5",
    "@tiptap/extension-link": "^2.11.5",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/extension-table": "^2.11.5",
    "@tiptap/extension-table-cell": "^2.11.5",
    "@tiptap/extension-table-header": "^2.11.5",
    "@tiptap/extension-table-row": "^2.11.5",
    "@tiptap/extension-task-item": "^2.11.5",
    "@tiptap/extension-task-list": "^2.11.5",
    "@tiptap/extension-underline": "^2.11.5",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "lowlight": "^3.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tiptap-markdown": "^0.8.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "7zip-bin": "^5.2.0",
    "electron": "^33.3.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "sharp": "^0.34.5",
    "vite": "^5.4.11"
  }
}
